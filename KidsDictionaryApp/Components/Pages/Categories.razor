@page "/categories"
@using KidsDictionaryApp.Models
@using KidsDictionaryApp.Services.Interfaces
@inject IWordRepository WordRepository
@inject IWordHistoryService HistoryService

<ProfileGuard>
<div class="dictionary-page">
    <h1 class="app-title">🏷️ Categories</h1>
    <p class="app-subtitle">Browse words by category</p>

    @if (_words == null)
    {
        <div class="loading-section">
            <div class="loading-spinner">⏳ Loading...</div>
        </div>
    }
    else if (_categories.Count == 0)
    {
        <div class="status-message">No categories found.</div>
    }
    else
    {
        <div class="category-list">
            @foreach (var category in _categories.OrderBy(c => c.Key))
            {
                <div class="category-card">
                    <button class="category-header" @onclick="() => ToggleCategory(category.Key)">
                        <span class="category-name">🏷️ @category.Key</span>
                        <span class="category-count">@category.Value.Count word@(category.Value.Count == 1 ? "" : "s")</span>
                        <span class="category-chevron">@(_expandedCategories.Contains(category.Key) ? "▲" : "▼")</span>
                    </button>
                    @if (_expandedCategories.Contains(category.Key))
                    {
                        <div class="word-list category-word-list">
                            @foreach (var word in category.Value.OrderBy(w => w.WordText))
                            {
                                <div class="word-list-item @(_selectedWord?.Id == word.Id ? "selected" : "")" @onclick="() => SelectWord(word)">
                                    <div class="word-list-content">
                                        <span class="word-list-text">@word.WordText</span>
                                        @if (!string.IsNullOrWhiteSpace(word.PartOfSpeech))
                                        {
                                            <div class="word-list-metadata">
                                                <span class="metadata-badge-small type-badge">@word.PartOfSpeech</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                @if (_selectedWord?.Id == word.Id)
                                {
                                    <div class="inline-word-detail">
                                        <WordDetailCard Word="_selectedWord"
                                                        ShowCloseButton="true"
                                                        OnClose="CloseDetail"
                                                        OnSynonymClick="SelectWordByText" />
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>
</ProfileGuard>

@code {
    private List<Word>? _words;
    private Dictionary<string, List<Word>> _categories = new();
    private HashSet<string> _expandedCategories = new();
    private Word? _selectedWord;

    protected override async Task OnInitializedAsync()
    {
        _words = (await WordRepository.GetAllWordsAsync())
            .OrderBy(w => w.WordText)
            .ToList();

        _categories = _words
            .Where(w => !string.IsNullOrWhiteSpace(w.Category))
            .GroupBy(w => w.Category!.Trim())
            .ToDictionary(g => g.Key, g => g.ToList());

        // Categories are collapsed by default
        // Users can click to expand individual categories
    }

    private void ToggleCategory(string category)
    {
        if (!_expandedCategories.Remove(category))
        {
            _expandedCategories.Add(category);
        }
    }

    private async Task SelectWord(Word word)
    {
        if (_selectedWord?.Id == word.Id)
        {
            _selectedWord = null;
        }
        else
        {
            _selectedWord = word;
            await HistoryService.AddAsync(word.WordText);
        }
    }

    private void CloseDetail()
    {
        _selectedWord = null;
    }

    private async Task SelectWordByText(string wordText)
    {
        var found = _words?.FirstOrDefault(w =>
            w.WordText.Equals(wordText, StringComparison.OrdinalIgnoreCase));

        if (found != null)
        {
            // Expand the category that contains the synonym so the inline card is visible.
            if (!string.IsNullOrWhiteSpace(found.Category))
            {
                _expandedCategories.Add(found.Category);
            }
            _selectedWord = found;
        }
        else
        {
            _selectedWord = await WordRepository.GetWordAsync(wordText);
        }

        if (_selectedWord != null)
        {
            await HistoryService.AddAsync(_selectedWord.WordText);
        }
    }
}
