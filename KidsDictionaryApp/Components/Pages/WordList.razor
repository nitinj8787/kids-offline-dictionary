@page "/wordlist"
@using KidsDictionaryApp.Models
@using KidsDictionaryApp.Services.Interfaces
@inject IWordRepository WordRepository

<div class="dictionary-page">
    <h1 class="app-title">📚 Word List</h1>
    <p class="app-subtitle">All words available in the dictionary</p>

    @if (_words == null)
    {
        <div class="loading-section">
            <div class="loading-spinner">⏳ Loading...</div>
        </div>
    }
    else
    {
        <div class="search-bar" style="margin-bottom: 1rem;">
            <input class="search-input"
                   type="text"
                   placeholder="Filter words..."
                   @bind="_filter"
                   @bind:event="oninput" />
        </div>

        var filtered = string.IsNullOrWhiteSpace(_filter)
            ? _words
            : _words.Where(w => w.WordText.Contains(_filter.Trim(), StringComparison.OrdinalIgnoreCase)).ToList();

        @if (filtered.Count == 0)
        {
            <div class="status-message">No words found matching "@_filter".</div>
        }
        else
        {
            <p class="app-subtitle">Showing @filtered.Count of @_words.Count words</p>

            @foreach (var group in filtered.Where(w => !string.IsNullOrEmpty(w.WordText)).GroupBy(w => w.WordText[0].ToString().ToUpper()).OrderBy(g => g.Key))
            {
                <h3 class="word-group-header">@group.Key</h3>
                <div class="word-list">
                    @foreach (var word in group.OrderBy(w => w.WordText))
                    {
                        <div class="word-list-item @(_selectedWord?.Id == word.Id ? "selected" : "")" @onclick="() => SelectWord(word)">
                            <div class="word-list-content">
                                <span class="word-list-text">@word.WordText</span>
                                @if (!string.IsNullOrWhiteSpace(word.Type) || !string.IsNullOrWhiteSpace(word.Category))
                                {
                                    <div class="word-list-metadata">
                                        @if (!string.IsNullOrWhiteSpace(word.Type))
                                        {
                                            <span class="metadata-badge-small type-badge">@word.Type</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(word.Category))
                                        {
                                            <span class="metadata-badge-small category-badge">@word.Category</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        @if (_selectedWord?.Id == word.Id)
                        {
                            <div class="inline-word-detail">
                                <WordDetailCard Word="_selectedWord"
                                                ShowCloseButton="true"
                                                OnClose="CloseDetail"
                                                OnSynonymClick="SelectWordByText" />
                            </div>
                        }
                    }
                </div>
            }
        }
    }
</div>

@code {
    private List<Word>? _words;
    private string _filter = string.Empty;
    private Word? _selectedWord;

    protected override async Task OnInitializedAsync()
    {
        _words = (await WordRepository.GetAllWordsAsync())
            .OrderBy(w => w.WordText)
            .ToList();
    }

    private void SelectWord(Word word)
    {
        _selectedWord = _selectedWord?.Id == word.Id ? null : word;
    }

    private void CloseDetail()
    {
        _selectedWord = null;
    }

    private async Task SelectWordByText(string wordText)
    {
        // First look in the full word list so the inline card becomes visible.
        var found = _words?.FirstOrDefault(w =>
            w.WordText.Equals(wordText, StringComparison.OrdinalIgnoreCase));

        if (found != null)
        {
            // Clear the filter so the synonym word is visible in the list.
            _filter = string.Empty;
            _selectedWord = found;
        }
        else
        {
            // Fall back to a database lookup when the word isn't in the local list.
            _selectedWord = await WordRepository.GetWordAsync(wordText);
        }
    }
}
