@page "/about"

<div class="about-page">
    <div class="about-hero">
        <div class="floating-emojis" aria-hidden="true">
            <span class="float-emoji" style="--delay:0s; --x:5%;">📖</span>
            <span class="float-emoji" style="--delay:0.8s; --x:15%;">⭐</span>
            <span class="float-emoji" style="--delay:1.6s; --x:75%;">🎮</span>
            <span class="float-emoji" style="--delay:2.4s; --x:88%;">🔍</span>
            <span class="float-emoji" style="--delay:3.2s; --x:50%;">🎯</span>
        </div>
        <h1 class="about-title">Welcome to Kids Dictionary! 🎉</h1>
        <p class="about-subtitle">Your super-fun word adventure starts here!</p>
        <div class="about-mascot" title="Dictionary Owl">🦉</div>
        <p class="mascot-speech">Hi! I'm Ollie the Owl 🦉 Let me show you all the cool things you can do here!</p>
    </div>

    <div class="features-grid">

        <div class="feature-card card-blue" tabindex="0">
            <div class="feature-emoji">🔍</div>
            <h2 class="feature-title">Word Search</h2>
            <p class="feature-desc">
                Type any word and instantly find out what it means!
                Learning new words is like finding hidden treasure! 💎
            </p>
            <a href="/" class="feature-btn">Try it now!</a>
        </div>

        <div class="feature-card card-purple" tabindex="0">
            <div class="feature-emoji">🎤</div>
            <h2 class="feature-title">Voice Search</h2>
            <p class="feature-desc">
                Too busy to type? Just speak the word out loud and
                let the magic microphone do the rest! ✨
            </p>
            <a href="/" class="feature-btn">Speak up!</a>
        </div>

        <div class="feature-card card-green" tabindex="0">
            <div class="feature-emoji">⭐</div>
            <h2 class="feature-title">Favourites</h2>
            <p class="feature-desc">
                Found a super cool word? Save it to your favourites
                so you can find it again super fast! 🚀
            </p>
            <a href="/favorites" class="feature-btn">My Favourites</a>
        </div>

        <div class="feature-card card-orange" tabindex="0">
            <div class="feature-emoji">🕐</div>
            <h2 class="feature-title">History</h2>
            <p class="feature-desc">
                Go back in time and see all the words you've looked up!
                Watch yourself become a word genius! 🧠
            </p>
            <a href="/history" class="feature-btn">My History</a>
        </div>

        <div class="feature-card card-teal" tabindex="0">
            <div class="feature-emoji">📚</div>
            <h2 class="feature-title">Word List</h2>
            <p class="feature-desc">
                Browse through hundreds of amazing words from A to Z!
                How many can you learn today? 🏆
            </p>
            <a href="/wordlist" class="feature-btn">Browse Words</a>
        </div>

        <div class="feature-card card-pink" tabindex="0">
            <div class="feature-emoji">🏷️</div>
            <h2 class="feature-title">Categories</h2>
            <p class="feature-desc">
                Words sorted into fun groups — animals, colours, food and more!
                Pick a category and explore! 🌈
            </p>
            <a href="/categories" class="feature-btn">Explore!</a>
        </div>

        <div class="feature-card card-yellow" tabindex="0">
            <div class="feature-emoji">🎮</div>
            <h2 class="feature-title">Match Game</h2>
            <p class="feature-desc">
                Match each word to its meaning in this super fun game!
                Score big and show off your word skills! 🌟
            </p>
            <a href="/match-game" class="feature-btn">Play now!</a>
        </div>

        <div class="feature-card card-red" tabindex="0">
            <div class="feature-emoji">🎯</div>
            <h2 class="feature-title">Hangman</h2>
            <p class="feature-desc">
                Guess the letters one by one to save the day!
                Can you figure out the secret word? 🕵️
            </p>
            <a href="/hangman" class="feature-btn">Let's play!</a>
        </div>

    </div>

    <div class="about-footer-banner">
        <p class="footer-banner-text">🌟 Ready to start your word adventure? 🌟</p>
        <a href="/" class="footer-cta-btn">🔍 Start Searching!</a>
    </div>
</div>
