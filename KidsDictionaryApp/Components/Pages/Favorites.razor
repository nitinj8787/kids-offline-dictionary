@page "/favorites"
@using KidsDictionaryApp.Models
@using KidsDictionaryApp.Services.Interfaces
@inject IFavoritesService FavoritesService
@inject IWordRepository WordRepository

<div class="dictionary-page">
    <h1 class="app-title">⭐ Favorites</h1>
    <p class="app-subtitle">Words you've saved as favorites</p>

    @if (_favorites == null)
    {
        <div class="loading-section">
            <div class="loading-spinner">⏳ Loading...</div>
        </div>
    }
    else if (_favorites.Count == 0)
    {
        <div class="status-message">No favorites yet. Star a word to save it here! ⭐</div>
    }
    else
    {
        <div class="word-list">
            @foreach (var item in _favorites)
            {
                <div class="word-list-item @(_selectedWordText == item.WordText ? "selected" : "")">
                    <span class="word-list-text" @onclick="() => SelectWordByText(item.WordText)">@item.WordText</span>
                    <button class="btn-remove-favorite" @onclick="() => RemoveFavorite(item.WordText)" title="Remove from favorites">
                        ✕
                    </button>
                </div>
                @if (_selectedWordText == item.WordText)
                {
                    <div class="inline-word-detail">
                        <WordDetailCard Word="_selectedWord"
                                        ShowCloseButton="true"
                                        OnClose="CloseDetail"
                                        OnSynonymClick="SelectWordByText" />
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    private List<FavoriteWord>? _favorites;
    private Word? _selectedWord;
    private string? _selectedWordText;

    protected override async Task OnInitializedAsync()
    {
        _favorites = await FavoritesService.GetFavoritesAsync();
    }

    private async Task RemoveFavorite(string word)
    {
        if (_selectedWordText == word)
        {
            _selectedWord = null;
            _selectedWordText = null;
        }
        await FavoritesService.RemoveAsync(word);
        _favorites = await FavoritesService.GetFavoritesAsync();
    }

    private void CloseDetail()
    {
        _selectedWord = null;
        _selectedWordText = null;
    }

    private async Task SelectWordByText(string wordText)
    {
        _selectedWordText = wordText;
        _selectedWord = await WordRepository.GetWordAsync(wordText);
    }
}
