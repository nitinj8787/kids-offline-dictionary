@page "/"
@using KidsDictionaryApp.ViewModels
@using KidsDictionaryApp.Services.Interfaces
@inject DictionaryViewModel ViewModel
@inject IWordHistoryService HistoryService
@implements IDisposable

<ProfileGuard>
<div class="dictionary-page">
    <div class="search-section">
        <h1 class="app-title">📖 Kids Dictionary</h1>
        <p class="app-subtitle">Type a word to learn what it means!</p>

        @if (_todayCount > 0)
        {
            <p class="today-words-badge">🌟 You've looked up <strong>@_todayCount</strong> word@(_todayCount == 1 ? "" : "s") today!</p>
        }

        <div class="search-bar">
            <input class="search-input"
                   type="text"
                   placeholder="Type a word here..."
                   @bind="ViewModel.SearchText"
                   @bind:event="oninput"
                   @onkeyup="OnKeyUp" />
            <button class="btn-search" @onclick="SearchAndRefreshCount"
                    disabled="@ViewModel.IsLoading">
                🔍 Search
            </button>
            <button class="btn-voice @(ViewModel.IsListening ? "listening" : "")"
                    @onclick="ViewModel.ListenAsync"
                    title="Search by voice"
                    disabled="@(ViewModel.IsLoading || ViewModel.IsListening)">
                🎤
            </button>
        </div>
    </div>

    @if (ViewModel.IsLoading)
    {
        <div class="loading-section">
            <div class="loading-spinner">⏳ Looking it up...</div>
        </div>
    }

    @if (!string.IsNullOrEmpty(ViewModel.StatusMessage))
    {
        <div class="status-message">@ViewModel.StatusMessage</div>
    }

    @if (ViewModel.CurrentWord != null)
    {
        <WordDetailCard Word="ViewModel.CurrentWord"
                        ShowCloseButton="false"
                        OnSynonymClick="SearchSynonym" />
    }
</div>
</ProfileGuard>

@code {
    private int _todayCount;

    protected override async Task OnInitializedAsync()
    {
        _todayCount = await HistoryService.GetTodayCountAsync();
        ViewModel.PropertyChanged += OnViewModelPropertyChanged;
    }

    private void OnViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAndRefreshCount();
        }
    }

    private async Task SearchAndRefreshCount()
    {
        await ViewModel.SearchAsync();
        _todayCount = await HistoryService.GetTodayCountAsync();
    }

    private async Task SearchSynonym(string word)
    {
        ViewModel.SearchText = word;
        await SearchAndRefreshCount();
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
    }
}

